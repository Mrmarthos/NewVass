	  /** 
	  * @description: (bulkBefore) Consigue el Id de Usuarios que tengan rol
      *               - Responsable de area
      *                 y tengan el mismo area de las LDP insertadas/Updateadas              
	  **
	  * @Autor: Noemi Escudero del Olmo (23/11/2018)
	  **
	  * @Modificacion: 
	  **
	  * @Parametro: - mapRolId: 	set de nombres de rol de usuario
	  **
	  * @return:    - Map<String,List<User>>: mapa con key area, value el lista de Usuarios que cumplen condición
	  **
	  */
    public static Map<String,List<User>> queryResponsableArea(List<Linea_de_Proyecto__c> listLDP, Map<String,Id> mapRolId) 
    {
        Set<String> setAreas = new Set<String>();
        Set<String> setSede = new Set<String>();
        List<User> listUser = new List<User>();
        Id responsableArea = mapRolId.get('Responsable_de_area');
        Id responsableAreaNateevo = mapRolId.get('Lider_de_consejo_Nateevo');
        
        Map<String,List<User>> mapAreaUser = new Map<String,List<User>>();

        //Como el OppTeam se borra siempre y se rehace, ya sea insert o update necesito todas las areas hayan cambiado o no
        for (Linea_de_Proyecto__c ldp : listLDP)
        {
            if(String.isnotBlank(ldp.area__c)) //aunque esto ya se comprueba antes pero...
            {
                setAreas.add(ldp.area__c);
                setSede.add(ldp.Sede__c);
            }            
        }
        system.debug('SEEEEEEDEED' + listLDP);
        if(listLDP.size()!=0){
        //Se busca el Id de los usuarios que tengan area y sean del rol Responsable de área
        mapAreaUser = (Map<String,List<User>>) Utils.buildGroupStringMap([SELECT Id, area__c, UserRoleId FROM User WHERE area__c IN :setAreas 
                                                                                                                   AND (UserRoleId = :responsableArea
                                                                                                                    OR UserRoleId =: responsableAreaNateevo) AND(Sede__c IN :setSede)
                              
                                                                                                                                                                                  AND User.IsActive = true], 'area__c');
        }
        return mapAreaUser;
    }

    /** 
	  * @description: (bulkBefore) Consigue el Id de Usuarios que tengan rol
      *               - Gerente de operaciones
      *                 y tengan la misma gerencias de las LDP insertadas/Updateadas              
	  **
	  * @Autor: Noemi Escudero del Olmo (27/11/2018)
	  **
	  * @Modificacion: 
	  **
	  * @Parametro: - mapRolId: 	set de nombres de rol de usuario
	  **
	  * @return:    - Map<String,List<User>>: mapa con key area, value el lista de Usuarios que cumplen condición
	  **
	  */
      public static Map<String,List<User>> queryGerenteOperaciones(List<Linea_de_Proyecto__c> listLDP, Map<String,Id> mapRolId) 
      {
          Set<String> setGerencias = new Set<String>();
          List<User> listUser = new List<User>();
          Id gerenteOperaciones = mapRolId.get('Gerente_de_operaciones');
          Id gerenciaNateevo = mapRolId.get('Jefe_Clan_Nateevo');
          Id gerenciaGlobal= mapRolId.get('Jefe_de_clan_global');
          Map<String,List<User>> mapGerenciaUser = new Map<String,List<User>>();
          Set<String> setSede = new Set<String>();
          //Como el OppTeam se borra siempre y se rehace, ya sea insert o update necesito todas las areas hayan cambiado o no
          for (Linea_de_Proyecto__c ldp : listLDP)
          {
              if(String.isnotBlank(ldp.gerencia__c)) //aunque esto ya se comprueba antes pero...
              {
                  setGerencias.add(ldp.gerencia__c);
                  setSede.add(ldp.Sede__c);
              }            
          }
          system.debug('seeeeededee'+ setSede);
          if(setSede.size()!=0 || setGerencias.size()!=0){
          //Se busca el Id de los usuarios que tengan area y sean del rol Gerente de operaciones
          mapGerenciaUser = (Map<String,List<User>>) Utils.buildGroupStringMap([SELECT Id, gerencia__c, UserRoleId FROM User WHERE gerencia__c IN :setGerencias AND (((UserRoleId = :gerenteOperaciones OR  UserRoleId = :gerenciaNateevo)  AND (Sede__c IN :setSede)) OR UserRoleId = :gerenciaGlobal)  AND User.IsActive = true], 'gerencia__c');
          }
          system.debug('Mapa gerencias'+ mapGerenciaUser);
          return mapGerenciaUser;
      }

