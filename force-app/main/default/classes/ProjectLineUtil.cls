                                                CreatedBy.EmployeeNumber
                                        FROM Linea_de_Proyecto__c
                                        WHERE Id IN :IdsPreventa  AND Oportunidad__r.stageName IN :Constants.ESTADOS_OPP_RELACIONADA_PREVENTA And Sede__c!='1410' AND  (Oportunidad__r.Sede_Venta__r.Name IN  :Constants.SEDE_VENTA_SINCRO_SAP  OR Sede__c IN :Constants.SEDE_SINCRO_SAP) ];     
                                        
               }
	
                if(IdsEjecucion.size()>0) 
                {
                    //se recuperan los datos a enviar a SAP -- EJECUCION
                    lpsEjecucion = [SELECT
                                                Id, 
                                                Codigo_SAP_Ejecucion__c,
                                                Name,
