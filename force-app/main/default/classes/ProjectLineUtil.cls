    /**
     * Marca las lineas de proyecto al ser insertadas sobre una oportunidad:
     *  si no tienen lineas previas y no indican cual de las insertadas es la principal, una cualquiera es la principal
     **
     * @author: amartinez (2018/11/14)
     */
    public static List<Linea_de_proyecto__c> markPrimaries(List<SObject> newList, List<Opportunity> allOpportunities)
    {
        Map<Id, Opportunity> idToOppty = new Map<Id, Opportunity>(allOpportunities);

        // Buscamos las oportunidad asociadas que les estemos insertando una linea principal
        Set<Id> opportunityHasMain = new Set<Id>();
        for (Linea_de_proyecto__c projLine : (List<Linea_de_proyecto__c>) newList)
        {
            if (projLine.Linea_principal__c && !opportunityHasMain.contains(projLine.Oportunidad__c))
            {
                opportunityHasMain.add(projLine.Oportunidad__c);
            }
        }

        // Recorremos todas las lineas de proyecto y marcamos las que
        //  - No existe linea previa para esa oportunidad Y
        //  - No se indica de las insertadas cual es la principal Y
        //    - si se inserta 1 > esa será la principal
        //    - si se insertan N > cualquiera será la principal
        for (Linea_de_proyecto__c projLine : (List<Linea_de_proyecto__c>) newList)
        {
            if (idToOppty.get(projLine.Oportunidad__c).Lineas_de_Proyecto__r.isEmpty())
            {
                if (!opportunityHasMain.contains(projLine.Oportunidad__c))
                {
                    opportunityHasMain.add(projLine.Oportunidad__c);
                    projLine.Linea_principal__c = true;
                  
                }
            }
        }

        return newList;
    }

	/**
    *@description: permite cambiar una línea como principal y desmarcar las demás para una misma oportunidad.
    *@param name Description: List<SObject> newList = Nuevas LP | map<Id,SObject> oldList = Estado anterior de las  LP
    *@author name: rpolvera
    *@date date: 11/01/2018
    *@change name date description: Nuevo Método.
    *@throws Exception: 
    *@where description: 
    *@see class/method: ProjectLineHandler.beforeUpdate
    **/ 
    public static List<Linea_de_proyecto__c> markPrimariesUpdate(List<SObject> newList, map<Id,SObject> oldList)
    {
        Set<Id> opportunityHasMain = new Set<Id>();
        Set<Id> IdLPApply = new Set<Id>();
        Map<Id, Linea_de_proyecto__c> idToLp = (Map<Id, Linea_de_proyecto__c>)oldList;
        for (Linea_de_proyecto__c projLine : (List<Linea_de_proyecto__c>) newList) 
        {
            if (projLine.Linea_principal__c != idToLp.get(projLine.Id).Linea_principal__c
            &&  idToLp.get(projLine.Id).Linea_principal__c == false ) 
            {
                opportunityHasMain.add(projLine.Oportunidad__c);
                IdLPApply.add(projLine.Id);
                FLAG_LPRINCIPAL = true;
                //Se marca la flag a true, la siguiente vuelta no entra por el error de desmarcado manual de la casilla 
                //Linea principal
            }
            else if (projLine.Linea_principal__c != idToLp.get(projLine.Id).Linea_principal__c
            &&  idToLp.get(projLine.Id).Linea_principal__c == true && FLAG_LPRINCIPAL == false
            ) 
            {
                //Si se desmarca de manera manual la casilla de línea principal entra por aqui.
               //projLine.addError('Only Line should be mark as "Main Line"');
            }
        }
        //Se recuperan las LP, las que hemos marcado como nueva LP principal
        if (opportunityHasMain.size()>0)
        { 
        //las lineas que no se modificarán en este flujo, las que se deben limpiar Linea_principal__c = false
        //se realiza una actualización de las lp que no han disparado el trigger y que pertenecen a la opp de la lp 
        //que si ha disparado el trigger                                                                  
            List<Linea_de_proyecto__c> limpiarLp = [SELECT  Id, 
                                                            Linea_principal__c 
                                                    FROM Linea_de_proyecto__c 
                                                    WHERE Oportunidad__c IN : opportunityHasMain
                                                    AND Id NOT IN : IdLPApply
                                                    AND Linea_principal__c = true];
            for (Linea_de_proyecto__c projLine : limpiarLp) 
            {
               projLine.Linea_principal__c = false;
            }
            Update limpiarLp;
        } 
        return newList;
    }

     /**
     * Marca los checkbox de validacion de los usuarios para cada etapa si estos estan correctamente cumplimentados
     **
     * @author: jquintana (2018/11/22) 
     */
    public static List<Linea_de_proyecto__c> validateUsers(List<SObject> newList)
    {
        for (Linea_de_proyecto__c pl : (List<Linea_de_proyecto__c>) newList)
        {
            pl.Validacion_Crossobject_Preventa__c = FALSE;
            pl.Validacion_Crossobject_Sincro__c = FALSE;
            if (pl.Jefe_de_Proyecto_de_Preventa__c != null && pl.Responsable_de_LDP__c != null)
            {
                pl.Validacion_Crossobject_Preventa__c = TRUE;
            }
            if (pl.Jefe_de_Proyecto_de_Preventa__c != null && pl.Responsable_de_LDP__c != null && pl.Jefe_de_Proyecto_de_Ejecucion__c != null)
            {
                pl.Validacion_Crossobject_Sincro__c = TRUE;
            }
        }		

        return newList;
    }


