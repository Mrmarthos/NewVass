        Integer i;
        if(opptys==null){
            opptys=new List<Opportunity>();
        }
        // Generamos por cada oportunidad, para cada gestor/responsable de la oportunidad y cada responsable de linea un nuevo miembro (todos únicos) 
        for (Opportunity opp : opptys)
