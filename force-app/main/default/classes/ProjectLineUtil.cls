    /**
     * Realiza las consultas necesarias para el equipo de oportunidad, pudiendo pasarsele objetos Opportunity y Linea_de_Proyecto__c, tanto en lista (para insert) como en lista y mapa (para update)
     *  al principio estaban en el trigger mismo, pero viendo que se repetía la query en tres sitios distintos...
     **
     * @author: amartinez (2018/11/15)
     */
    public class QueryOpportunityTeamResult 
    {
        public List<OpportunityTeamMember> opportunityTeamMembers;
        public List<Opportunity> opportunities;
    }

    public static QueryOpportunityTeamResult queryOpportunityTeam(List<sObject> newList) 
    {
        return queryOpportunityTeam(newList, null);
    }

    public static QueryOpportunityTeamResult queryOpportunityTeam(List<sObject> newList, Map<Id, sObject> oldMap) 
    {
        QueryOpportunityTeamResult res = new QueryOpportunityTeamResult();

        Set<Id> opportunityIds = new Set<Id>();
        Schema.SObjectType sobjectType = newList != null? newList.get(0).getSObjectType(): oldMap.get(oldMap.keySet().iterator().next()).getSObjectType();

        // ** Opportunity **
        if (sobjectType == Opportunity.getSObjectType()) 
        {
            if (oldMap == null) 
            {
                // En insert, hacer la query con todas las oportunidades
                for (SObject sobj : newList)
                {
                    opportunityIds.add(sobj.Id);
                }
            }
            else  
            {
                // En update de oppty hacer la query con las oportunidades que cambian sus responsables/gestores
                for (SObject sobj : newList)
                {
                    Opportunity oldOpp = (Opportunity)oldMap.get(sobj.Id);
                    Opportunity newOpp = (Opportunity)Trigger.newMap.get(sobj.Id);
                    if (oldOpp.Bid_Manager__c != newOpp.Bid_Manager__c ||
                        oldOpp.Offering__c != newOpp.Offering__c ||
                        oldOpp.Business_Value__c != newOpp.Business_Value__c)  
                    {
                        opportunityIds.add(sobj.Id);
                    }
                }
            }
        }

        // ** ProjectLine **
        if (sobjectType == Linea_de_Proyecto__c.getSObjectType())
        {
            // En delete, recalculamos pero a partir de las oportunidades de los borrados
            if (newList == null && oldMap != null) 
            {
                for (Id id : oldMap.keySet())
                {
                    Linea_de_Proyecto__c projLine = (Linea_de_Proyecto__c)oldMap.get(id);
                    opportunityIds.add(projLine.Oportunidad__c);
                }
            } 
            else // En update e insert igual
            {
                for (Linea_de_Proyecto__c projLine : (List<Linea_de_Proyecto__c>)newList)
                {
                    opportunityIds.add(projLine.Oportunidad__c);
                }
            }
        }
    

        if (opportunityIds.isEmpty())
        {
         
            res.opportunities = new List<Opportunity>();
            res.opportunityTeamMembers = new List<OpportunityTeamMember>();
            return res;
        }
        system.debug('ID oportunidades' +opportunityIds);
        res.opportunityTeamMembers = [SELECT Id,AutoGenerated__c FROM OpportunityTeamMember WHERE OpportunityId IN :opportunityIds];
        res.opportunities = [SELECT Id, Bid_Manager__c, Offering__c, Business_Value__c, (SELECT Id, Responsable_de_LDP__c, area__c, gerencia__c,Oficina_Tecnica__c,Sede__c FROM Lineas_de_Proyecto__r) FROM Opportunity WHERE Id IN :opportunityIds];
        
    
        return res;
    }
    
    
