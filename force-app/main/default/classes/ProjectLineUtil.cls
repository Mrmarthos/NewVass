            // Añadimos el bid manager

			/*
            List<Comerciales_Multibooking__c> Relaciones =[ SELECT  Comercial__c from Comerciales_Multibooking__c WHERE Oportunidad__c = :opp.id]; 
               
                for (i=0; i<Relaciones.size();i++){

                        List<Comerciales_Multibooking__c> accts =[ SELECT  Oportunidad__r.OwnerId from Comerciales_Multibooking__c WHERE id = :Relaciones.get(i).id]; 
                        system.debug(relaciones.size());
                        system.debug(accts.size());
                        system.debug(i);
                          if(Relaciones.get(i).Comercial__c!=accts.get(0).Oportunidad__r.OwnerId){
                              opportunityTeamMembers.add( new OpportunityTeamMember(
                            
                              OpportunityAccessLevel   = Constants.DEFAULT_ACCESS_LEVEL_ACC_WHEN_SHARING_OPPTY,
                              UserId               = Relaciones.get(i).Comercial__c,
                              OpportunityId                = opp.id,
                              TeamMemberRole                    =Constants.DEFAULT_TEAM_MEMBER_ROLE_OPPORTUNITY_TEAM
                            
                  
                        ));
                          }
                    }
           
           */
            if (opp.Bid_Manager__c != null)
            {
                idsUserPorOpp.add(opp.Bid_Manager__c);
                opportunityTeamMembers.add(new OpportunityTeamMember(
                    OpportunityId = opp.Id,
                    OpportunityAccessLevel = Constants.DEFAULT_ACCESS_LEVEL_OPPORTUNITY_TEAM,
                    UserId = opp.Bid_Manager__c,
                    TeamMemberRole = Constants.DEFAULT_TEAM_MEMBER_ROLE_OPPORTUNITY_TEAM
                ));
            }
            // Añadimos el responsable de offering
            if (opp.Offering__c != null)
            {
                idsUserPorOpp.add(opp.Offering__c);
                opportunityTeamMembers.add(new OpportunityTeamMember(
                    OpportunityId = opp.Id,
                    OpportunityAccessLevel = Constants.DEFAULT_ACCESS_LEVEL_OPPORTUNITY_TEAM,
                    UserId = opp.Offering__c,
                    TeamMemberRole = Constants.DEFAULT_TEAM_MEMBER_ROLE_OPPORTUNITY_TEAM
                ));
            }
            // Añadimos el responsable de business value
            if (opp.Business_Value__c != null)
            {
                idsUserPorOpp.add(opp.Business_Value__c);
                opportunityTeamMembers.add(new OpportunityTeamMember(
                    OpportunityId = opp.Id,
                    OpportunityAccessLevel = Constants.DEFAULT_ACCESS_LEVEL_OPPORTUNITY_TEAM,
                    UserId = opp.Business_Value__c,
                    TeamMemberRole = Constants.DEFAULT_TEAM_MEMBER_ROLE_OPPORTUNITY_TEAM
                ));
            }
            // Añadimos los responsables de cada línea de proyecto
            for (Linea_de_Proyecto__c projectLine : opp.Lineas_de_Proyecto__r) 
            {

                system.debug('NUEEEEVO FORR'+projectLine );
                if (projectLine.Responsable_de_LDP__c != null && !idsUserPorOpp.contains(projectLine.Responsable_de_LDP__c))
                {
                    idsUserPorOpp.add(projectLine.Responsable_de_LDP__c);
                    opportunityTeamMembers.add(new OpportunityTeamMember(
                        OpportunityId = opp.Id,
                        OpportunityAccessLevel = Constants.DEFAULT_ACCESS_LEVEL_OPPORTUNITY_TEAM,
                        UserId = projectLine.Responsable_de_LDP__c,
                        TeamMemberRole = Constants.DEFAULT_TEAM_MEMBER_ROLE_OPPORTUNITY_TEAM
                    ));
                }
                //Aprovecho para conseguir las áreas de las LDP
                if (String.isNotBlank(projectLine.area__c) ||String.isNotBlank(projectLine.Oficina_tecnica__c) )
                {
                    listLDP.add(projectLine);
                }
            }
            addedMembers.put(opp,idsUserPorOpp);
        }

            //Consigo los Responsables de las areas de las LDP que hay
            //La key es el area, y luego contiene una lista de todos los Users que lo tienen y con dicho rol
            mapAreaUser = queryResponsableArea(listLDP, mapRolId);
            //Consigo los Gerentes de operaciones de las LDP que hay
            //La key es el area, y luego contiene una lista de todos los Users que lo tienen y con dicho rol
            mapGerenciaUser = queryGerenteOperaciones(listLDP, mapRolId);

            //Consigo los resposables de oficinas de de las LDP que hay
            //La key es la oficina, y luego contiene una lista de todos los Users que lo tienen y con dicho rol
            //mapFilialesUser =QueryEquipoIntercompany(listLDP, mapRolId);

        for (Opportunity opp : opptys)
        {
            // Añado los Gerentes de operaciones y los Responsables de Área que tengan la misma área que la LDP
            for (Linea_de_Proyecto__c projectLine : opp.Lineas_de_Proyecto__r) 
            {
                if (String.isNotBlank(projectLine.area__c))
                {
                    List<User> listUser = new List<User>(); //Resetear
                    //Consigo la lista de usuarios con dicho área
                    listUser = mapAreaUser.get(projectLine.area__c); 
                    if (listUser != null) //Si no hay usuarios en ese área, no poner ninguno
                    {                   
                        for (User u : listUser)
                        {   
                            if(!addedMembers.get(opp).contains(u.Id))
                            {
                                addedMembers.get(opp).add(u.Id);
                                opportunityTeamMembers.add(new OpportunityTeamMember(
                                    OpportunityId = opp.Id,
                                    OpportunityAccessLevel = Constants.DEFAULT_ACCESS_LEVEL_OPPORTUNITY_TEAM,
                                    UserId = u.Id,
                                    TeamMemberRole = Constants.DEFAULT_TEAM_MEMBER_ROLE_OPPORTUNITY_TEAM
                                ));
                            }
                        }
                    }
                }

                if (String.isNotBlank(projectLine.gerencia__c))
                {
                    List<User> listUser = new List<User>(); //Resetear
                    //Consigo la lista de usuarios con dicho área
                    listUser = mapGerenciaUser.get(projectLine.gerencia__c);
                    if (listUser != null) //Si no hay usuarios en ese área, no poner ninguno
                    {                   
                        for (User u : listUser)
                        {   
                            if(!addedMembers.get(opp).contains(u.Id))
                            {
                                addedMembers.get(opp).add(u.Id);
                                opportunityTeamMembers.add(new OpportunityTeamMember(
                                    OpportunityId = opp.Id,
                                    OpportunityAccessLevel = Constants.DEFAULT_ACCESS_LEVEL_OPPORTUNITY_TEAM,
                                    UserId = u.Id,
                                    TeamMemberRole = Constants.DEFAULT_TEAM_MEMBER_ROLE_OPPORTUNITY_TEAM
                                ));
                            }
                        }
                    }
                }

                 if (String.isNotBlank(projectLine.Oficina_Tecnica__c))
                {
                    List<User> listUser = new List<User>(); //Resetear
                    //Consigo la lista de usuarios con dicho área
                    listUser = mapFilialesUser.get(projectLine.Oficina_Tecnica__c);
                    if (listUser != null) //Si no hay usuarios en ese área, no poner ninguno
                    {                   
                        for (User u : listUser)
                        {   
                            if(!addedMembers.get(opp).contains(u.Id))
                            {
                                addedMembers.get(opp).add(u.Id);
                                opportunityTeamMembers.add(new OpportunityTeamMember(
                                    OpportunityId = opp.Id,
                                    OpportunityAccessLevel = Constants.DEFAULT_ACCESS_LEVEL_OPPORTUNITY_TEAM,
                                    UserId = u.Id,
                                    TeamMemberRole = Constants.DEFAULT_TEAM_MEMBER_ROLE_OPPORTUNITY_TEAM
                                ));
                            }
                        }
                    }
                }
            }
        }
     
        for(integer k=0;k<opportunityTeamMembers.size();k++){
            
            opportunityTeamMembers.get(k).AutoGenerated__c=true;
        }
 
        return opportunityTeamMembers;
    }

    /**
     * Envía las lineas de proyecto a sincronizar con SAP 
     **
     * @author: gserrano y rpolvera (2018/11/16) 
     */
     /*
     Este método se llamará desde un trigger y desde un batch
     */
    public static void serializeAndSendProjectLines(list<Linea_de_Proyecto__c> lineasProyecto, String path, map<Id,SObject> oldMap, Boolean pospuesto)
    {
        /*Si se ha llamado desde un trigger*/
        if(Trigger.isExecuting)
        {
            //Cuando se inserta una LP van a ser preventa las que se envian a Salesforce, ya que solo se pueden incluir LP hasta el estado de 
            //Opp igual a preventa
            if (Trigger.isInsert) 
            {
                Set<String> idsLP = new Set<String>();
                for (Linea_de_Proyecto__c lp : lineasProyecto)  
                {
                    idsLP.add(lp.Id);
                }
                String serializedPreventa;
                //se recuperan las lineas de proyecto relacionadas a estas Oportunidades
              
                List<Linea_de_Proyecto__c> preventas = [SELECT
                                                        Id,
                                                        Codigo_SAP_Preventa__c,
                                                        Name,
                                                        Nombre_SAP__c,
                                                        Area__c,
                                                        Oficina_tecnica__c,
                                                        Fecha_Fin__c, 
                                                        Fecha_Inicio__c,
                                                        Gerencia__c,
                                                        Jefe_de_Proyecto_de_Preventa__r.Codigo_de_empleado__c,
                                                        Margen_real__c,
                                                        Importe_total_2__c,
                                                        Responsable_de_LDP__r.EmployeeNumber,
                                                        Tecnologia__c,
                                                        Oportunidad__r.Proyecto_extraordinario__c,
                                                        Oportunidad__r.CreatedDate,
                                                        Oportunidad__r.Codigo_de_oportunidad__c,
                                                        Oportunidad__r.Account.ID_SAP__c,
                                                        Oportunidad__r.Owner.EmployeeNumber,
                                                        Oportunidad__r.Offering__r.EmployeeNumber,
                                                        Oportunidad__r.Offering__r.Profile.Id,
                                                        Oportunidad__r.mercado__c,
                                                        Comercial_Intercompany__r.EmployeeNumber,
                                                        CreatedById,
                                                        Fabricantes__c,
                                                        Sede__c,
                                                        Org_Ventas__c,
                                                        NEW_Nombre_SAP__c,
                                                        CreatedBy.EmployeeNumber
                                                        FROM Linea_de_Proyecto__c
                                                        WHERE Id IN :idsLP
                                                        AND Oportunidad__r.Account.ID_SAP__c != null 
                                                        AND Oportunidad__r.Account.ID_SAP__c != ''
                                                        AND Validado_para_Preventa__c = true
                                                        AND Oportunidad__r.StageName = 'Preventa'
                                                        And Sede__c!='1410'
                                                        AND  (Oportunidad__r.Sede_Venta__r.Name IN  :Constants.SEDE_VENTA_SINCRO_SAP  OR Sede__c IN :Constants.SEDE_SINCRO_SAP) ];
                system.debug('Prebemtas nulas'+preventas);

                if(preventas.size()>0) 
                {
                    
                    serializedPreventa = JSON.serialize(preventas);
                    CalloutUtil.sendObjsToSAPFromTrigger(serializedPreventa, path, 'Linea_de_Proyecto__c');
                }
            }
            else if (Trigger.isUpdate) 
            {   
                String serializedPreventa;
                List<Linea_de_proyecto__c> preventa = new List<Linea_de_proyecto__c>();
                List<String> camposAComprobarPreventa = Constants.CAMPOS_COMPROBAR_LINEA_PREVENTA;
                Set<String> IdsPreventa = new Set<String>();
                List<Linea_de_Proyecto__c> sincronizaPreventa = new List<Linea_de_Proyecto__c>();

                String serializedEjecucion;
                List<Linea_de_proyecto__c> ejecucion = new List<Linea_de_proyecto__c>();
                List<String> camposAComprobarEjecucion = Constants.CAMPOS_COMPROBAR_LINEA_EJECUCION;
                Set<String> IdsEjecucion = new Set<String>();
                List<Linea_de_Proyecto__c> lpsEjecucion = new List<Linea_de_Proyecto__c>();
                List<Linea_de_Proyecto__c> sincronizaEjecucion = new List<Linea_de_Proyecto__c>();
            
                Set<String> proyectos = new Set<String>(); 

                //Si tiene codigo_SAP_Ejecucion__c informado, pasa a ser ejecución y se altualizará en sap este tipo
                for ( Linea_de_proyecto__c lp : lineasProyecto ){
                        if ( (lp.Codigo_SAP_Ejecucion__c != null && !lp.Codigo_SAP_Ejecucion__c.equals('')) || 
                             (lp.Validado_para_Sincronizacion__c == true && lp.Listo_para_sincronizar__c == true && lp.No_aplica_para_ejecucion__c == false)) 
                        {
                            ejecucion.add(lp);
                        }
                        else 
                        {
                            preventa.add(lp);
                        }
                    }
                   
                //comprobamos que se han modificado los preventa
                for( Linea_de_proyecto__c lp : (List< Linea_de_proyecto__c>)preventa)
                { 
                    for(String campo : camposAComprobarPreventa)
                    {
                        if(lp.get(campo) != (( Linea_de_proyecto__c)oldMap.get(lp.Id)).get(campo))
                        {
                            IdsPreventa.add(lp.Id);
                        }
                    }
                }

             
                //comprobamos que se han modificado los ejecución
                for( Linea_de_proyecto__c lp : (List< Linea_de_proyecto__c>)ejecucion)
                { 
                    for(String campo : camposAComprobarEjecucion)
                    {
                        if(lp.get(campo) != (( Linea_de_proyecto__c)oldMap.get(lp.Id)).get(campo))
                        {
                            IdsEjecucion.add(lp.Id);
                        }
                    }
                }
                
                if(IdsPreventa.size()>0) 
                {
                    //se recuperan los datos a enviar a SAP -- PREVENTA
                    sincronizaPreventa = [SELECT
                                                Id, 
                                                Codigo_SAP_Preventa__c,
                                                Name,
                                                Area__c,
                                                Nombre_SAP__c,
                                                Oficina_tecnica__c,
                                                Fecha_Fin__c,
                                                Fecha_Inicio__c,
                                                Gerencia__c,
                                                Jefe_de_Proyecto_de_Preventa__r.Codigo_de_empleado__c,
                                                Margen_real__c,
                                                Importe_total_2__c,
