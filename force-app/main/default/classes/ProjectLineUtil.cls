                                                                  AND Listo_para_sincronizar__c = true
                                    								And Sede__c!='1410'
                                                                  AND No_aplica_para_ejecucion__c = false
                                                                    AND   (Oportunidad__r.Sede_Venta__r.Name IN  :Constants.SEDE_VENTA_SINCRO_SAP  OR Sede__c IN :Constants.SEDE_SINCRO_SAP)];  
                    //Se cladifican las linea de ejecución que tienen un proyecto registrado en SAP
                    for (Linea_de_proyecto__c lp : lpsEjecucion) {
                        //Si su Oportunidad tiene ID_SAP__c, ya se encuentra en SAP y se procesa de manera normal 
                       if (String.isNotBlank(lp.Oportunidad__r.ID_SAP__c)) 
                       {
                          sincronizaEjecucion.add(lp);
                       }
                       //Si aún no tiene su Opp en SAP, se guarda su ID en un SET y posteriormente se procesarán
                       else 
                       {
                           proyectos.add(lp.Oportunidad__r.Id);
                       }
                    }
                }
                //si encontramos registros lps de preventa que sincroniza, los serializamos y los enviamos
                if (sincronizaPreventa.size()>0) 
                { 
                    serializedPreventa = JSON.serialize(sincronizaPreventa);               
                    CalloutUtil.sendObjsToSAPFromTrigger(serializedPreventa, Constants.SAP_LPS_PREVENTA_PATH, 'Linea_de_Proyecto__c');
                }
                //si encontramos registros lps de ejecución que sincroniza, los serializamos y los enviamos
                if (sincronizaEjecucion.size()>0) 
                {
                    serializedEjecucion = JSON.serialize(sincronizaEjecucion);
                    CalloutUtil.sendObjsToSAPFromTrigger(serializedEjecucion, Constants.SAP_LPS_EJECUCION_PATH, 'Linea_de_Proyecto_Ejecucion__c');
                }
                //si encontramos proyectos que enviar a SAP se envía su Id para que el siguiente método lo inserte.
                if (proyectos.size()>0) {
                   
                }
            }
        }
        /*Si viene del batch el proceso será distinto*/
        else 
        {
            String serializedLps = JSON.serialize(lineasProyecto);
            CalloutUtil.sendObjsToSAP(serializedLps, path, 'Linea_de_Proyecto__c', pospuesto); 
