<aura:component  controller="GetDivisa" implements="force:appHostable,flexipage:availableForAllPageTypes" access="global" >
         <aura:attribute name="Divisa" type="String"/>
       <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>
		<div class="slds-box slds-theme_shade">
    	<lightning:icon iconName="standard:currency" alternativeText="Event" />

            <b> Las cantidades de los paneles se muestran en: {!v.Divisa}</b>
 
           
           </div>
</aura:component>