<?xml version="1.0" encoding="UTF-8"?>
<Workflow xmlns="http://soap.sforce.com/2006/04/metadata">
    <alerts>
        <fullName>Asignacion_SW</fullName>
        <description>Asignacion SW</description>
        <protected>false</protected>
        <recipients>
            <recipient>Responsable_de_SW</recipient>
            <type>role</type>
        </recipients>
        <senderType>CurrentUser</senderType>
        <template>unfiled$public/Asignacion_SW</template>
    </alerts>
    <alerts>
        <fullName>EPPM</fullName>
        <ccEmails>andres.martos@vasscompany.com,carlos.aliaga@t4sadvance.com,miquel.perez@t4sadvance.com</ccEmails>
        <description>EPPM</description>
        <protected>false</protected>
        <recipients>
            <field>Jefe_de_Proyecto_de_Preventa__c</field>
            <type>contactLookup</type>
        </recipients>
        <senderType>CurrentUser</senderType>
        <template>unfiled$public/EPPM</template>
    </alerts>
    <alerts>
        <fullName>EppmHitos</fullName>
        <ccEmails>facturacion@t4sadvance.com,andres.martos@vasscompany.com</ccEmails>
        <description>EppmHitos</description>
        <protected>false</protected>
        <recipients>
            <type>owner</type>
        </recipients>
        <senderType>CurrentUser</senderType>
        <template>unfiled$public/EPPMHitos</template>
    </alerts>
    <alerts>
        <fullName>PEP_denegado</fullName>
        <description>PEP denegado</description>
        <protected>false</protected>
        <recipients>
            <type>owner</type>
        </recipients>
        <senderType>CurrentUser</senderType>
        <template>unfiled$public/PEP_denegado</template>
    </alerts>
    <alerts>
        <fullName>SW_Asignado</fullName>
        <description>SW Asignado</description>
        <protected>false</protected>
        <recipients>
            <field>Responsable_de_LDP__c</field>
            <type>userLookup</type>
        </recipients>
        <senderType>CurrentUser</senderType>
        <template>unfiled$public/SW_Asignado</template>
    </alerts>
    <rules>
        <fullName>Asignacion SW</fullName>
        <actions>
            <name>Asignacion_SW</name>
            <type>Alert</type>
        </actions>
        <active>true</active>
        <formula>OR(ISPICKVAL(Oportunidad__r.StageName, &quot;Solicitada&quot;),ISPICKVAL(Oportunidad__r.StageName, &quot;Preventa&quot;)) &amp;&amp; ISBLANK(Responsable_de_LDP__c) &amp;&amp; RecordType.DeveloperName = &quot;Licencias&quot;</formula>
        <triggerType>onCreateOrTriggeringUpdate</triggerType>
    </rules>
    <rules>
        <fullName>SW Asignado</fullName>
        <actions>
            <name>SW_Asignado</name>
            <type>Alert</type>
        </actions>
        <active>true</active>
        <formula>OR(ISPICKVAL(Oportunidad__r.StageName, &quot;Solicitada&quot;),ISPICKVAL(Oportunidad__r.StageName, &quot;Preventa&quot;)) &amp;&amp; ISCHANGED(Responsable_de_LDP__c) &amp;&amp; RecordType.DeveloperName = &quot;Licencias&quot;</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
</Workflow>
